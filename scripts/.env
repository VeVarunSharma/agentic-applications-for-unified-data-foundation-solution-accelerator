# Fabric Ontology Lab Configuration
# Copy this file to .env and fill in your values
#
# NOTE: If you used 'azd up' to deploy, Azure service endpoints are loaded
# automatically from .azure/<env>/.env - no need to configure them here!
#
# If infrastructure is ALREADY PROVISIONED (no .azure folder):
#   Run: python scripts/generate_env_from_azure.py -g <resource-group-name>
#   This will auto-populate Azure endpoints from your existing resources.

# --- Default Set Deploy App to true ---
AZURE_ENV_DEPLOY_APP=false
USE_DATA_AGENT=false
AZURE_ENV_ONLY=true

# --- Microsoft Fabric (not used in Azure-only mode) ---
FABRIC_WORKSPACE_ID=6cbea430-d222-4c6c-86bb-0e22afb8fa43

# Solution name prefix
SOLUTION_NAME=clearwater4s75m

# --- Data Folder ---
DATA_FOLDER='data/customdata'

# --- AI Data Generation ---
INDUSTRY='Healthcare'
USECASE='Hospital admissions analytics and clinical order management for Clearwater Health Authority'
DATA_SIZE=small

# --- Agent IDs (auto-populated by scripts) ---
FABRIC_AGENT_ID=
FOUNDRY_AGENT_ID=

# =============================================================================
# AZURE SERVICES - Only needed if NOT using 'azd up'
# If you ran 'azd up', these are loaded from .azure/<env>/.env automatically
# =============================================================================

# --- Azure AI Foundry ---
AZURE_AI_AGENT_ENDPOINT=https://aisa-clearwater4s75m.services.ai.azure.com/api/projects/aifp-clearwater4s75m
AZURE_AI_ENDPOINT=https://aisa-clearwater4s75m.services.ai.azure.com
AZURE_CHAT_MODEL=gpt-4o-mini
AZURE_EMBEDDING_MODEL=text-embedding-3-small

# --- Azure AI Search ---
AZURE_AI_SEARCH_ENDPOINT=https://srch-clearwater4s75m.search.windows.net

# --- Added from Azure ---
AZURE_SUBSCRIPTION_ID=294d2b76-b638-4b2f-ab57-28ea1953eab5
SOLUTION_NAME=clearwater4s75m
RESOURCE_GROUP_NAME=rg-clearwater
AZURE_OPENAI_ENDPOINT=https://aisa-clearwater4s75m.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_MODEL=gpt-4o-mini
AZURE_CHAT_MODEL=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_EMBEDDING_MODEL=text-embedding-3-small
AZURE_AI_AGENT_MODEL_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_AI_SEARCH_ENDPOINT=https://srch-clearwater4s75m.search.windows.net
AZURE_AI_SEARCH_NAME=srch-clearwater4s75m
AZURE_AI_SEARCH_INDEX=knowledge_index
AZURE_COSMOSDB_ACCOUNT=cosmos-clearwater4s75m
AZURE_COSMOSDB_DATABASE=db_conversation_history
